<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>回鄉造材｜南投農林剩餘資源天然建材創生計畫</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Arial','Microsoft JhengHei',sans-serif;background:#F7F9F7;color:#1A1A1A}
  .hero{background:linear-gradient(135deg,#1A3D28 0%,#2E6B3E 60%,#3E8E53 100%);color:white;padding:60px 40px;text-align:center}
  .hero-sub{font-size:14px;opacity:.75;letter-spacing:3px;margin-bottom:12px}
  .hero-title{font-size:56px;font-weight:900;letter-spacing:8px;margin-bottom:10px}
  .hero-desc{font-size:20px;opacity:.9;font-weight:300;margin-bottom:30px}
  .hero-tags{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
  .tag{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);padding:6px 18px;border-radius:20px;font-size:13px}
  .section{max-width:1000px;margin:0 auto;padding:50px 24px 0}
  .section-title{font-size:22px;font-weight:800;color:#1A3D28;border-left:5px solid #2E6B3E;padding-left:14px;margin-bottom:28px}
  .stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px}
  .stat-card{background:white;border-radius:12px;padding:24px 20px;box-shadow:0 2px 12px rgba(0,0,0,.07);border-top:4px solid #2E6B3E;text-align:center}
  .stat-num{font-size:34px;font-weight:900;color:#2E6B3E;line-height:1}
  .stat-unit{font-size:14px;color:#666;margin-top:4px}
  .stat-label{font-size:13px;color:#444;margin-top:8px;line-height:1.4}
  .pain-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
  .pain-card{border-radius:12px;padding:20px;border:2px solid}
  .pain-card.health{background:#FFF3E0;border-color:#E65100}
  .pain-card.carbon{background:#FFEBEE;border-color:#C62828}
  .pain-title{font-size:15px;font-weight:800;margin-bottom:10px}
  .pain-card.health .pain-title{color:#E65100}
  .pain-card.carbon .pain-title{color:#C62828}
  .pain-item{font-size:13px;color:#444;margin-bottom:6px;padding-left:16px;position:relative;line-height:1.5}
  .pain-item::before{content:'✗';position:absolute;left:0;font-weight:700}
  .pain-card.health .pain-item::before{color:#E65100}
  .pain-card.carbon .pain-item::before{color:#C62828}
  .comp-table{width:100%;border-collapse:collapse;background:white;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.07);margin-bottom:16px}
  .comp-table th{background:#1A3D28;color:white;padding:10px 12px;font-size:13px;text-align:center}
  .comp-table td{padding:10px 12px;font-size:13px;border-bottom:1px solid #EEE;text-align:center}
  .comp-table td:first-child{text-align:left;font-weight:700}
  .comp-table tr:last-child td{background:#E8F5E9!important;font-weight:700;color:#1B5E20}
  .comp-table tr:nth-child(even) td{background:#F9F9F9}
  .check{color:#2E6B3E;font-size:16px;font-weight:900}
  .cross{color:#C62828;font-size:16px;font-weight:900}
  .delta{color:#E65100;font-size:16px;font-weight:900}
  .flow{display:flex;align-items:center;gap:0;margin-bottom:12px}
  .flow-box{flex:1;background:white;border-radius:10px;padding:18px 14px;box-shadow:0 2px 10px rgba(0,0,0,.07);text-align:center;border-top:3px solid}
  .flow-box.green{border-color:#2E6B3E}.flow-box.blue{border-color:#1565C0}.flow-box.amber{border-color:#E65100}.flow-box.red{border-color:#C62828}
  .flow-icon{font-size:28px;margin-bottom:8px}
  .flow-title{font-size:14px;font-weight:800;color:#1A1A1A;margin-bottom:6px}
  .flow-items{font-size:12px;color:#666;line-height:1.7}
  .flow-arrow{font-size:22px;color:#2E6B3E;padding:0 6px;flex-shrink:0;font-weight:900}
  .role-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
  .role-card{background:white;border-radius:12px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.07)}
  .role-card.us{border-top:4px solid #2E6B3E}
  .role-card.them{border-top:4px solid #1565C0}
  .role-tag{font-size:11px;font-weight:800;letter-spacing:2px;margin-bottom:8px}
  .role-card.us .role-tag{color:#2E6B3E}
  .role-card.them .role-tag{color:#1565C0}
  .role-name{font-size:18px;font-weight:900;margin-bottom:14px;color:#1A1A1A}
  .role-item{font-size:13px;color:#333;margin-bottom:8px;padding-left:18px;position:relative;line-height:1.5}
  .role-item::before{content:'▸';position:absolute;left:0;font-weight:700}
  .role-card.us .role-item::before{color:#2E6B3E}
  .role-card.them .role-item::before{color:#1565C0}
  .rev-table{width:100%;border-collapse:collapse;background:white;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.07)}
  .rev-table th{background:#1A3D28;color:white;padding:12px 16px;font-size:13px;text-align:left}
  .rev-table td{padding:12px 16px;font-size:13px;border-bottom:1px solid #EEE}
  .rev-table tr:last-child td{border-bottom:none}
  .rev-table tr:nth-child(even) td{background:#F5FAF6}
  .badge{display:inline-block;padding:3px 10px;border-radius:10px;font-size:11px;font-weight:700}
  .badge-y1{background:#C8E6C9;color:#1B5E20}
  .badge-y2{background:#BBDEFB;color:#0D47A1}
  .timeline-wrap{background:white;border-radius:12px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,.07);overflow-x:auto}
  .tl-grid{display:grid;grid-template-columns:200px repeat(8,1fr);gap:4px;margin-bottom:4px}
  .tl-label{font-size:13px;font-weight:700;color:#1A1A1A;padding:8px 10px;display:flex;align-items:center}
  .tl-year{text-align:center;padding:8px 4px;font-size:12px;font-weight:800;border-radius:6px;color:white}
  .y1bg{background:#2E6B3E}.y2bg{background:#1565C0}
  .tl-q{text-align:center;padding:6px 4px;font-size:11px;font-weight:700;border-radius:6px;color:white}
  .q-y1{background:#4CAF50}.q-y2{background:#42A5F5}
  .tl-cell{border-radius:5px;height:32px}
  .on-y1{background:linear-gradient(135deg,#4CAF50,#2E6B3E)}
  .on-y2{background:linear-gradient(135deg,#42A5F5,#1565C0)}
  .off{background:#F0F0F0}
  .year-cards{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px}
  .year-card{border-radius:12px;padding:24px}
  .year-card.y1c{background:linear-gradient(135deg,#E8F5E9,#C8E6C9);border:2px solid #4CAF50}
  .year-card.y2c{background:linear-gradient(135deg,#E3F2FD,#BBDEFB);border:2px solid #42A5F5}
  .year-card-title{font-size:16px;font-weight:800;margin-bottom:14px}
  .y1c .year-card-title{color:#1B5E20}.y2c .year-card-title{color:#0D47A1}
  .year-item{font-size:13px;color:#333;margin-bottom:8px;padding-left:18px;position:relative;line-height:1.5}
  .year-item::before{content:'▸';position:absolute;left:0;font-weight:700}
  .y1c .year-item::before{color:#2E6B3E}.y2c .year-item::before{color:#1565C0}
  .kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
  .kpi-card{background:white;border-radius:10px;padding:18px 14px;box-shadow:0 2px 10px rgba(0,0,0,.07);border-left:4px solid #2E6B3E}
  .kpi-num{font-size:11px;font-weight:800;color:#2E6B3E;letter-spacing:1px;margin-bottom:8px}
  .kpi-title{font-size:14px;font-weight:700;color:#1A1A1A;margin-bottom:6px;line-height:1.3}
  .kpi-desc{font-size:12px;color:#666;line-height:1.5}
  .partner-card{background:white;border-radius:12px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,.07);display:grid;grid-template-columns:1fr 1fr;gap:28px}
  .partner-name{font-size:20px;font-weight:900;color:#1A3D28;margin-bottom:6px}
  .partner-sub{font-size:13px;color:#666;margin-bottom:16px}
  .partner-stat{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px}
  .pstat-num{font-size:22px;font-weight:900;color:#2E6B3E}
  .pstat-label{font-size:11px;color:#888}
  .cert-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
  .cert{background:#E8F5E9;color:#1B5E20;padding:4px 10px;border-radius:6px;font-size:12px;font-weight:700}
  .award-item{font-size:13px;color:#333;margin-bottom:7px;padding-left:20px;position:relative}
  .award-item::before{content:'🏆';position:absolute;left:0;font-size:11px}
  .award-item.top{font-weight:700;color:#1A3D28}
  .team-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
  .team-card{background:white;border-radius:12px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.07)}
  .team-role{font-size:11px;font-weight:800;color:#2E6B3E;letter-spacing:2px;margin-bottom:8px}
  .team-name{font-size:22px;font-weight:900;color:#1A1A1A;margin-bottom:4px}
  .team-title{font-size:13px;color:#666;margin-bottom:16px;line-height:1.5}
  .skill-item{font-size:13px;color:#333;margin-bottom:7px;padding-left:18px;position:relative}
  .skill-item::before{content:'▸';position:absolute;left:0;color:#2E6B3E;font-weight:700}
  .footer{background:#1A3D28;color:rgba(255,255,255,.7);text-align:center;padding:30px;margin-top:60px;font-size:13px}
  @media(max-width:700px){
    .stats-grid,.pain-grid,.year-cards,.team-grid,.partner-card,.role-grid{grid-template-columns:1fr}
    .flow{flex-direction:column}.flow-arrow{transform:rotate(90deg)}
    .kpi-grid{grid-template-columns:repeat(2,1fr)}
  }
</style>
</head>
<body>
<div class="hero">
  <div class="hero-sub">中興新村地方創生育成村 第六期進駐申請</div>
  <div class="hero-title">回鄉造材</div>
  <div class="hero-desc">南投農林剩餘資源天然建材創生計畫</div>
  <div class="hero-tags">
    <span class="tag">科技創生</span><span class="tag">地方創生執行團隊</span>
    <span class="tag">實體進駐</span><span class="tag">南投竹山・鹿谷</span><span class="tag">1＋1 年計畫</span>
  </div>
</div>

<div class="section">
  <div class="section-title">一、場域與市場：為什麼是現在？</div>
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-num">75,275</div><div class="stat-unit">公頃</div><div class="stat-label">台灣竹林總面積<br>南投為孟宗竹・桂竹主產區</div></div>
    <div class="stat-card"><div class="stat-num">1,000萬</div><div class="stat-unit">支 / 年</div><div class="stat-label">黃金時代竹材年產量<br>今日大面積荒廢<br>廢料缺乏高值化出路</div></div>
    <div class="stat-card"><div class="stat-num">47.36</div><div class="stat-unit">噸CO₂ / 公頃・年</div><div class="stat-label">竹林年固碳量<br>為一般林木的 3–6 倍<br>生態價值極高</div></div>
    <div class="stat-card" style="border-color:#C62828"><div class="stat-num" style="color:#C62828">兩大</div><div class="stat-unit">結構性痛點</div><div class="stat-label">傳統建材的甲醛問題<br>＋ 砂石石材的高碳排<br>正是市場的核心缺口</div></div>
    <div class="stat-card" style="border-color:#1565C0"><div class="stat-num" style="color:#1565C0">60–75%</div><div class="stat-unit">法規要求</div><div class="stat-label">室內綠建材使用率法定門檻<br>台北市2024年起提高至75%<br>帶動全台市場需求</div></div>
    <div class="stat-card" style="border-color:#1565C0"><div class="stat-num" style="color:#1565C0">3,461億</div><div class="stat-unit">美元（2025年）</div><div class="stat-label">全球綠建材市場規模<br>CAGR 10.2%<br>2035年預計達9,141億美元</div></div>
  </div>

  <div class="pain-grid">
    <div class="pain-card health">
      <div class="pain-title">🧪 健康痛點——甲醛問題</div>
      <div class="pain-item">夾板、集成板含大量甲醛</div>
      <div class="pain-item">塑合板、美耐板含塑化劑</div>
      <div class="pain-item">燃燒時釋放有毒氣體</div>
      <div class="pain-item">消費端健康意識持續升高</div>
    </div>
    <div class="pain-card carbon">
      <div class="pain-title">🏭 碳排痛點——高碳建材</div>
      <div class="pain-item">砂石、石材、水泥類建材碳排極高</div>
      <div class="pain-item">建設業面臨ESG與淨零政策壓力</div>
      <div class="pain-item">企業採購端減碳需求迫切</div>
      <div class="pain-item">我們的賽道：農林廢料升級再造，幾乎零額外碳排</div>
    </div>
  </div>
</div>

<div class="section" style="padding-top:40px">
  <div class="section-title">二、現有建材競品分析</div>
  <table class="comp-table">
    <thead><tr><th>建材類型</th><th>無甲醛</th><th>低碳排</th><th>防潮</th><th>加工性</th><th>天然來源</th><th style="text-align:left">主要痛點</th></tr></thead>
    <tbody>
      <tr><td>夾板／集成板</td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td><td style="text-align:left">高甲醛、受潮膨脹、蟲蛀風險</td></tr>
      <tr><td>石膏板</td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="delta">△</span></td><td><span class="cross">✗</span></td><td style="text-align:left">易碎、防潮差、遇水粉化</td></tr>
      <tr><td>矽酸鈣板</td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td style="text-align:left">質感冷硬、加工性差、重量偏重</td></tr>
      <tr><td>塑合板／美耐板</td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="delta">△</span></td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td><td style="text-align:left">含塑化劑、燃燒產生有毒氣體</td></tr>
      <tr><td>天然植物纖維板材</td><td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td><td style="text-align:left">農林廢料升級再造，低碳天然 ✓</td></tr>
    </tbody>
  </table>
</div>

<div class="section" style="padding-top:40px">
  <div class="section-title">三、商業模式：從廢料到市場</div>
  <div class="flow">
    <div class="flow-box green"><div class="flow-icon">🌿</div><div class="flow-title">在地原料</div><div class="flow-items">南投竹山・鹿谷<br>竹材加工廢料<br>竹粉・竹屑・殘料</div></div>
    <div class="flow-arrow">▶</div>
    <div class="flow-box blue"><div class="flow-icon">⚙️</div><div class="flow-title">技術支援</div><div class="flow-items">先進材股份有限公司<br>完整成熟竹纖維技術<br>AI選竹配方系統</div></div>
